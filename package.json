{
  "name": "vistora-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Vistora is a backend-heavy digital catalogue and assisted wholesale selling platform for textile and fashion stores.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run dev --workspace @vistora/api",
    "dev:web": "npm run dev --workspace @vistora/web",
    "build": "npm run build --workspace @vistora/shared && npm run build --workspace @vistora/api && npm run build --workspace @vistora/web",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write .",
    "prisma:generate": "npm run prisma:generate --workspace @vistora/api",
    "prisma:migrate": "npm run prisma:migrate --workspace @vistora/api",
    "prisma:seed": "npm run prisma:seed --workspace @vistora/api"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "bcrypt": "^6.0.0"
  }
}
